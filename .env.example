# MongoDB Atlas Connection
# Replace with your actual MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/leave-manager?retryWrites=true&w=majority

# JWT Secret for authentication
# Generate a strong, random secret (at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-here-make-it-long-and-random

# Enables localhost-only admin routes when true.
ADMIN_ENABLED=false

# Controls temporary fallback scan for mixed teamId types in users collection.
# Default behavior when unset: enabled only in development, disabled otherwise.
ENABLE_TEAMID_TYPE_DRIFT_FALLBACK=false

# Optional comma-separated list of additional trusted origins for cookie-authenticated
# mutating requests (CSRF protection). Leave empty for same-origin only.
CSRF_ALLOWED_ORIGINS=

# Optional debug/error logging toggles (development only recommended).
DEBUG_LOGS=false
EXPOSE_ERROR_DETAILS=false

# Test-only toggle. Do not enable in production.
DISABLE_RATE_LIMIT=false

# Only set to true when all traffic is guaranteed to pass through a trusted reverse proxy.
TRUST_PROXY_HEADERS=false

# --- Email (Gmail SMTP via Nodemailer) — optional; leave unset to disable email.
# App Password: https://support.google.com/accounts/answer/185833
GMAIL_USER=ged.incorporated@gmail.com
GMAIL_APP_PASSWORD=
# Display name in emails
APP_NAME=Leave Manager
# Public base URL for links in emails (required in production)
APP_URL=https://your-deployment.vercel.app

# --- Telegram — optional
# Bot token from @BotFather (server-side only)
TELEGRAM_BOT_TOKEN=
# Bot username without @ — used by the Login Widget on the profile page (must be the same bot as the token)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourLeaveManagerBot
# Users must open @YourLeaveManagerBot in Telegram and tap Start once, or the bot cannot send them DMs (website login alone is not enough).
# Debug: Profile → “Send test Telegram message” calls POST /api/users/telegram/test (checks token, bot name match, and sendMessage).

# Bump this when you want a new “add your email / update” prompt for users who already saved email.
NEXT_PUBLIC_NOTIFICATION_PROMPT_VERSION=1

# Cron: Vercel sends this as Authorization: Bearer <value> when invoking scheduled jobs.
# Required in production for GET /api/cron/leave-reminders (leave start reminders at 10 and 5 days).
CRON_SECRET=
